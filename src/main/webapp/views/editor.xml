<?xml version="1.0" encoding="UTF-8"?>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/views/editor/create</string>
                <HypermediaService>
                    <parameters>
                        <list>
                            <PathVariable><path>/views/editor/{verb}</path></PathVariable>
                        </list>
                    </parameters>
                    <verbs>
                        <list>
                            <verb>
                                <name>create</name>
                                <page>/WEB-INF/pages/editor.jsp</page>
                                <service>/api/articles/{verb}</service>
                                <method>POST</method>
                                <redirect>/views/article/{slug}</redirect>
                            </verb>
                        </list>
                    </verbs>
                </HypermediaService>
            </entry>
            <entry>
                <string>/views/editor/*</string>
                <HypermediaService>
                    <parameters>
                        <list>
                            <PathVariable><path>/views/editor/{slug}/edit</path></PathVariable>
                        </list>
                    </parameters>
                    <verbs>
                        <list>
                            <verb>
                                <name>edit</name>
                                <page>/WEB-INF/pages/editor.jsp</page>
                                <service>/api/articles/{slug}</service>
                                <method>PUT</method>
                                <redirect>/views/article/{slug}</redirect>
                            </verb>
                        </list>
                    </verbs>
                </HypermediaService>
            </entry>
        </map>
    </routes>
</RoutedService>
