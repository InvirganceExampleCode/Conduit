<?xml version="1.0" encoding="UTF-8"?>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/views/article</string>
                <HypermediaService>
                    <parameters>
                        <list>
                            <PathVariable><path>/views/article/{slug}</path></PathVariable>
                        </list>
                    </parameters>
                    <page>/WEB-INF/pages/article.jsp</page>
                    <verbs>
                        <list>
                            <verb>
                                <name>delete</name>
                                <service>/api/articles/{slug}</service>
                                <method>DELETE</method>
                                <redirect>/</redirect>
                            </verb>
                        </list>
                    </verbs>
                </HypermediaService>
            </entry>
        </map>
    </routes>
</RoutedService>
