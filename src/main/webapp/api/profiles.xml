<?xml version="1.0" encoding="UTF-8"?>
<AuthenticatedService>
<service>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/api/profiles/*/follow</string>
                <RESTService>
                    <POST>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/profiles/{username}/follow</path></PathVariable>
                                    <SessionParameter><name>followerId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                insert into follows (follower_id, followed_id)
                                select :followerId, u.id
                                from users u
                                where u.username = :username and u.id <> :followerId
                                on conflict (follower_id, followed_id) do nothing
                            ]]></sql>
                        </UpdateService>
                    </POST>
                    <DELETE>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/profiles/{username}/follow</path></PathVariable>
                                    <SessionParameter><name>followerId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                delete from follows
                                where follower_id = :followerId
                                  and followed_id = (select id from users where username = :username)
                            ]]></sql>
                        </UpdateService>
                    </DELETE>
                </RESTService>
            </entry>
        </map>
    </routes>
</RoutedService>
</service>
<redirectToLogin>false</redirectToLogin>
</AuthenticatedService>
