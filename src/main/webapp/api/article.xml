<?xml version="1.0" encoding="UTF-8"?>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/api/article</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/api/article/{slug}</path></PathVariable>
                            <SessionParameter>
                                <name>currentUserId</name>
                                <sessionKey>currentUserId</sessionKey>
                                <defaultValue>0</defaultValue>
                            </SessionParameter>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    a.id as "id",
                                    a.author_id as "author_id",
                                    a.slug as "slug",
                                    a.title as "title",
                                    a.description as "description",
                                    cast(a.body as varchar) as "body",
                                    cast(a.created_at as varchar) as "created_at",
                                    cast(a.updated_at as varchar) as "updated_at",
                                    u.name as "username",
                                    u.slug as "profile_slug",
                                    u.bio as "bio",
                                    'https://www.gravatar.com/avatar/' || md5(lower(trim(u.email))) || '?d=identicon&s=80' as "image",
                                    (select count(*) from favorites f where f.article_id = a.id) as "favorites_count",
                                    exists(
                                        select 1 from favorites f
                                        where f.article_id = a.id and f.user_id = :currentUserId
                                    ) as "favorited",
                                    article_tag.name as "name"
                                from articles a
                                join users u on u.id = a.author_id
                                left join article_tags article_tag_link on article_tag_link.article_id = a.id
                                left join tags article_tag on article_tag.id = article_tag_link.tag_id
                                where a.slug = :slug
                                order by a.id, article_tag.name
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <transformers>
                        <list>
                            <SortedGroupByTransformer>
                                <fields>id,author_id,slug,title,description,body,created_at,updated_at,username,profile_slug,bio,image,favorites_count,favorited</fields>
                                <output>tagList</output>
                            </SortedGroupByTransformer>
                            <MarkdownTransformer>
                                <input>body</input>
                                <output>bodyHtml</output>
                            </MarkdownTransformer>
                        </list>
                    </transformers>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
            <entry>
                <string>/api/article/*/comments</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/api/article/{slug}/comments</path></PathVariable>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    c.id as "id",
                                    c.author_id as "author_id",
                                    c.body as "body",
                                    cast(c.created_at as varchar) as "created_at",
                                    cast(c.updated_at as varchar) as "updated_at",
                                    u.name as "username",
                                    u.slug as "profile_slug",
                                    u.bio as "bio",
                                    'https://www.gravatar.com/avatar/' || md5(lower(trim(u.email))) || '?d=identicon&s=80' as "image"
                                from comments c
                                join articles a on a.id = c.article_id
                                join users u on u.id = c.author_id
                                where a.slug = :slug
                                order by c.created_at, c.id
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
        </map>
    </routes>
</RoutedService>
