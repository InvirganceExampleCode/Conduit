<?xml version="1.0" encoding="UTF-8"?>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/api/articles</string>
                <PaginatedTableService id="article_pages">
                    <pageSize>20</pageSize>
                    <parameters>
                        <list>
                            <SessionParameter>
                                <name>currentUserId</name>
                                <sessionKey>currentUserId</sessionKey>
                                <defaultValue>0</defaultValue>
                            </SessionParameter>
                            <RequestParameter><name>tag</name></RequestParameter>
                        </list>
                    </parameters>
                    <page>
                        <RequestParameter><name>page</name><defaultValue>1</defaultValue></RequestParameter>
                    </page>
                    <search>
                        <RequestParameter><name>search</name></RequestParameter>
                    </search>
                    <sort>
                        <RequestParameter><name>sort</name><defaultValue>created_at</defaultValue></RequestParameter>
                    </sort>
                    <sortDirection>
                        <RequestParameter><name>descending</name><defaultValue>true</defaultValue></RequestParameter>
                    </sortDirection>
                    <columns>id, slug, title, description, created_at, updated_at, username, bio, image, favorites_count, favorited, name</columns>
                    <searchKeys>title, description, username</searchKeys>
                    <primaryKey>id</primaryKey>
                    <jndiName>jdbc/conduit</jndiName>
                    <sql><![CDATA[
                        select
                            a.id as id,
                            a.slug as slug,
                            a.title as title,
                            a.description as description,
                            cast(a.created_at as varchar) as created_at,
                            cast(a.updated_at as varchar) as updated_at,
                            u.username as username,
                            u.bio as bio,
                            'https://www.gravatar.com/avatar/' || lower(rawtohex(hash('MD5', stringtoutf8(lower(trim(u.email)))))) || '?d=identicon&s=80' as image,
                            (select count(*) from favorites f where f.article_id = a.id) as favorites_count,
                            exists(
                                select 1 from favorites f
                                where f.article_id = a.id and f.user_id = :currentUserId
                            ) as favorited,
                            article_tag.name as name
                        from articles a
                        join users u on u.id = a.author_id
                        left join article_tags article_tag_link on article_tag_link.article_id = a.id
                        left join tags article_tag on article_tag.id = article_tag_link.tag_id
                        where coalesce(cast(:tag as varchar), '') = ''
                           or exists(
                                select 1 from article_tags selected_at
                                join tags selected_tag on selected_tag.id = selected_at.tag_id
                                where selected_at.article_id = a.id and selected_tag.name = :tag
                           )
                    ]]></sql>
                    <transformers>
                        <list>
                            <SortedGroupByTransformer>
                                <fields>id,slug,title,description,created_at,updated_at,username,bio,image,favorites_count,favorited</fields>
                                <output>tagList</output>
                            </SortedGroupByTransformer>
                        </list>
                    </transformers>
                    <output><JSONOutput /></output>
                </PaginatedTableService>
            </entry>
            <entry>
                <string>/api/articles/count</string>
                <ref id="article_pages" />
            </entry>
            <entry>
                <string>/api/articles/*/favorite</string>
                <AuthenticatedService>
                <service>
                <RESTService>
                    <POST>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/articles/{slug}/favorite</path></PathVariable>
                                    <SessionParameter><name>userId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                merge into favorites (user_id, article_id) key(user_id, article_id)
                                select :userId, a.id from articles a where a.slug = :slug
                            ]]></sql>
                        </UpdateService>
                    </POST>
                    <DELETE>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/articles/{slug}/favorite</path></PathVariable>
                                    <SessionParameter><name>userId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                delete from favorites
                                where user_id = :userId
                                  and article_id = (select id from articles where slug = :slug)
                            ]]></sql>
                        </UpdateService>
                    </DELETE>
                </RESTService>
                </service>
                <redirectToLogin>false</redirectToLogin>
                </AuthenticatedService>
            </entry>
            <entry>
                <string>/api/articles/*/comments</string>
                <AuthenticatedService>
                <service>
                <RESTService>
                    <POST>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/articles/{slug}/comments</path></PathVariable>
                                    <SessionParameter><name>authorId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <ValidatedRequestParameter><name>body</name><label>Comment</label><maxLength>4000</maxLength></ValidatedRequestParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                insert into comments (id, article_id, author_id, body)
                                select next value for conduit_ids, a.id, :authorId, :body
                                from articles a
                                where a.slug = :slug and length(trim(:body)) > 0
                            ]]></sql>
                        </UpdateService>
                    </POST>
                </RESTService>
                </service>
                <redirectToLogin>false</redirectToLogin>
                </AuthenticatedService>
            </entry>
            <entry>
                <string>/api/articles/*/comments/*</string>
                <AuthenticatedService>
                <service>
                <RESTService>
                    <DELETE>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/articles/{slug}/comments/*</path></PathVariable>
                                    <PathVariable><path>/api/articles/*/comments/{commentId}</path></PathVariable>
                                    <SessionParameter><name>authorId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                delete from comments
                                where id = :commentId
                                  and author_id = :authorId
                                  and article_id = (select id from articles where slug = :slug)
                            ]]></sql>
                        </UpdateService>
                    </DELETE>
                </RESTService>
                </service>
                <redirectToLogin>false</redirectToLogin>
                </AuthenticatedService>
            </entry>
            <entry>
                <string>/api/articles/create</string>
                <AuthenticatedService>
                <service>
                <RESTService>
                    <POST>
                        <ReturningUpdateService>
                            <parameters>
                                <list>
                                    <ValidatedRequestParameter><name>title</name><label>Article title</label><maxLength>255</maxLength></ValidatedRequestParameter>
                                    <ValidatedRequestParameter><name>description</name><label>Description</label><maxLength>1024</maxLength></ValidatedRequestParameter>
                                    <ValidatedRequestParameter><name>body</name><label>Article body</label></ValidatedRequestParameter>
                                    <GeneratedSlugParameter />
                                    <SessionParameter><name>authorId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                    <ArticleTagsParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                insert into articles (id, author_id, slug, title, description, body)
                                values (next value for conduit_ids, :authorId, :slug, :title, :description, :body)
                            ]]></sql>
                            <children>
                                <map>
                                    <entry>
                                        <string>tagList</string>
                                        <string><![CDATA[
                                            merge into article_tags (article_id, tag_id) key(article_id, tag_id)
                                            select a.id, t.id
                                            from articles a,
                                            final table (
                                                merge into tags t
                                                using (values(cast(:tagName as varchar))) s(name)
                                                on t.name = s.name
                                                when matched then update set name = t.name
                                                when not matched then insert (id, name) values (next value for conduit_ids, s.name)
                                            ) t
                                            where a.slug = :slug
                                        ]]></string>
                                    </entry>
                                </map>
                            </children>
                            <returnParameters><list><string>slug</string></list></returnParameters>
                        </ReturningUpdateService>
                    </POST>
                </RESTService>
                </service>
                <redirectToLogin>false</redirectToLogin>
                </AuthenticatedService>
            </entry>
            <entry>
                <string>/api/articles/*</string>
                <AuthenticatedService>
                <service>
                <RESTService>
                    <PUT>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/articles/{slug}</path></PathVariable>
                                    <SessionParameter><name>authorId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <ValidatedRequestParameter><name>title</name><label>Article title</label><maxLength>255</maxLength></ValidatedRequestParameter>
                                    <ValidatedRequestParameter><name>description</name><label>Description</label><maxLength>1024</maxLength></ValidatedRequestParameter>
                                    <ValidatedRequestParameter><name>body</name><label>Article body</label></ValidatedRequestParameter>
                                    <CsrfParameter />
                                    <ArticleTagsParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <statements>
                                <list>
                                    <string><![CDATA[
                                        update articles
                                        set title = :title, description = :description, body = :body, updated_at = current_timestamp
                                        where slug = :slug and author_id = :authorId
                                    ]]></string>
                                    <string><![CDATA[
                                        delete from article_tags
                                        where article_id = (select id from articles where slug = :slug and author_id = :authorId)
                                    ]]></string>
                                </list>
                            </statements>
                            <children>
                                <map>
                                    <entry>
                                        <string>tagList</string>
                                        <string><![CDATA[
                                            merge into article_tags (article_id, tag_id) key(article_id, tag_id)
                                            select a.id, t.id
                                            from articles a,
                                            final table (
                                                merge into tags t
                                                using (values(cast(:tagName as varchar))) s(name)
                                                on t.name = s.name
                                                when matched then update set name = t.name
                                                when not matched then insert (id, name) values (next value for conduit_ids, s.name)
                                            ) t
                                            where a.slug = :slug and a.author_id = :authorId
                                        ]]></string>
                                    </entry>
                                </map>
                            </children>
                        </UpdateService>
                    </PUT>
                    <DELETE>
                        <UpdateService>
                            <parameters>
                                <list>
                                    <PathVariable><path>/api/articles/{slug}</path></PathVariable>
                                    <SessionParameter><name>authorId</name><sessionKey>currentUserId</sessionKey></SessionParameter>
                                    <CsrfParameter />
                                </list>
                            </parameters>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql>delete from articles where slug = :slug and author_id = :authorId</sql>
                        </UpdateService>
                    </DELETE>
                </RESTService>
                </service>
                <redirectToLogin>false</redirectToLogin>
                </AuthenticatedService>
            </entry>
        </map>
    </routes>
</RoutedService>
