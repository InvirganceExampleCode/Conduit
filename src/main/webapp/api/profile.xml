<?xml version="1.0" encoding="UTF-8"?>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/api/profile/*/comments</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/api/profile/{username}/comments</path></PathVariable>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    c.id as "id",
                                    c.body as "body",
                                    to_char(c.created_at at time zone 'UTC', 'YYYY-MM-DD"T"HH24:MI:SS.US"Z"') as "created_at",
                                    a.slug as "article_slug",
                                    a.title as "article_title"
                                from comments c
                                join users u on u.id = c.author_id
                                join articles a on a.id = c.article_id
                                where u.slug = :username
                                order by c.created_at desc, c.id desc
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
            <entry>
                <string>/api/profile/*/articles</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/api/profile/{username}/articles</path></PathVariable>
                            <RequestParameter><name>tab</name><defaultValue>articles</defaultValue></RequestParameter>
                            <SessionParameter>
                                <name>currentUserId</name>
                                <sessionKey>currentUserId</sessionKey>
                                <defaultValue>0</defaultValue>
                            </SessionParameter>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    a.slug as "slug",
                                    a.title as "title",
                                    a.description as "description",
                                    to_char(a.created_at at time zone 'UTC', 'YYYY-MM-DD"T"HH24:MI:SS.US"Z"') as "created_at",
                                    u.name as "username",
                                    u.slug as "profile_slug",
                                    'https://www.gravatar.com/avatar/' || md5(lower(trim(u.email))) || '?d=identicon&s=80' as "image",
                                    (select count(*) from favorites f where f.article_id = a.id) as "favorites_count",
                                    exists(
                                        select 1 from favorites f
                                        where f.article_id = a.id and f.user_id = :currentUserId
                                    ) as "favorited",
                                    article_tag.name as "name"
                                from articles a
                                join users u on u.id = a.author_id
                                left join article_tags article_tag_link on article_tag_link.article_id = a.id
                                left join tags article_tag on article_tag.id = article_tag_link.tag_id
                                where (
                                    :tab = 'favorited'
                                    and exists(
                                        select 1 from favorites profile_favorite
                                        join users profile_user on profile_user.id = profile_favorite.user_id
                                        where profile_favorite.article_id = a.id and profile_user.slug = :username
                                    )
                                ) or (
                                    :tab <> 'favorited' and u.slug = :username
                                )
                                order by a.created_at desc, a.id desc, article_tag.name
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <transformers>
                        <list>
                            <SortedGroupByTransformer>
                                <fields>slug,title,description,created_at,username,profile_slug,image,favorites_count,favorited</fields>
                                <output>tagList</output>
                            </SortedGroupByTransformer>
                        </list>
                    </transformers>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
            <entry>
                <string>/api/profile</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/api/profile/{username}</path></PathVariable>
                            <SessionParameter>
                                <name>currentUserId</name>
                                <sessionKey>currentUserId</sessionKey>
                                <defaultValue>0</defaultValue>
                            </SessionParameter>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    u.id as "id",
                                    u.name as "username",
                                    u.slug as "profile_slug",
                                    u.bio as "bio",
                                    'https://www.gravatar.com/avatar/' || md5(lower(trim(u.email))) || '?d=identicon&s=160' as "image",
                                    exists(
                                        select 1 from follows f
                                        where f.follower_id = :currentUserId and f.followed_id = u.id
                                    ) as "following"
                                from users u
                                where u.slug = :username
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
        </map>
    </routes>
</RoutedService>
