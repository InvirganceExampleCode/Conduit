<?xml version="1.0" encoding="UTF-8"?>
<RoutedService>
    <routes>
        <map>
            <entry>
                <string>/services/profile/*/articles</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/services/profile/{username}/articles</path></PathVariable>
                            <RequestParameter><name>tab</name><defaultValue>articles</defaultValue></RequestParameter>
                            <SessionParameter>
                                <name>currentUserId</name>
                                <sessionKey>currentUserId</sessionKey>
                                <defaultValue>0</defaultValue>
                            </SessionParameter>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    a.slug as "slug",
                                    a.title as "title",
                                    a.description as "description",
                                    cast(a.created_at as varchar) as "created_at",
                                    u.username as "username",
                                    'https://www.gravatar.com/avatar/' || lower(rawtohex(hash('MD5', stringtoutf8(lower(trim(u.email)))))) || '?d=identicon&s=80' as "image",
                                    (select count(*) from favorites f where f.article_id = a.id) as "favorites_count",
                                    exists(
                                        select 1 from favorites f
                                        where f.article_id = a.id and f.user_id = :currentUserId
                                    ) as "favorited",
                                    article_tag.name as "name"
                                from articles a
                                join users u on u.id = a.author_id
                                left join article_tags article_tag_link on article_tag_link.article_id = a.id
                                left join tags article_tag on article_tag.id = article_tag_link.tag_id
                                where (
                                    :tab = 'favorited'
                                    and exists(
                                        select 1 from favorites profile_favorite
                                        join users profile_user on profile_user.id = profile_favorite.user_id
                                        where profile_favorite.article_id = a.id and profile_user.username = :username
                                    )
                                ) or (
                                    :tab <> 'favorited' and u.username = :username
                                )
                                order by a.created_at desc, a.id desc, article_tag.name
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <transformers>
                        <list>
                            <SortedGroupByTransformer>
                                <fields>slug,title,description,created_at,username,image,favorites_count,favorited</fields>
                                <output>tagList</output>
                            </SortedGroupByTransformer>
                        </list>
                    </transformers>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
            <entry>
                <string>/services/profile</string>
                <SelectService>
                    <parameters>
                        <list>
                            <PathVariable><path>/services/profile/{username}</path></PathVariable>
                            <SessionParameter>
                                <name>currentUserId</name>
                                <sessionKey>currentUserId</sessionKey>
                                <defaultValue>0</defaultValue>
                            </SessionParameter>
                        </list>
                    </parameters>
                    <binding>
                        <QueryBinding>
                            <jndiName>jdbc/conduit</jndiName>
                            <sql><![CDATA[
                                select
                                    u.id as "id",
                                    u.username as "username",
                                    u.bio as "bio",
                                    'https://www.gravatar.com/avatar/' || lower(rawtohex(hash('MD5', stringtoutf8(lower(trim(u.email)))))) || '?d=identicon&s=160' as "image",
                                    exists(
                                        select 1 from follows f
                                        where f.follower_id = :currentUserId and f.followed_id = u.id
                                    ) as "following"
                                from users u
                                where u.username = :username
                            ]]></sql>
                        </QueryBinding>
                    </binding>
                    <output><JSONOutput /></output>
                </SelectService>
            </entry>
        </map>
    </routes>
</RoutedService>
